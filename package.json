{
  "name": "polyagent-oss",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @polyagent/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @polyagent/db generate",
    "db:migrate": "pnpm --filter @polyagent/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @polyagent/db migrate:deploy",
    "db:seed": "pnpm --filter @polyagent/db seed",
    "db:setup": "node scripts/db-setup.mjs",
    "verify:gamma": "node scripts/verify-gamma.mjs",
    "smoke": "node scripts/smoke-docker.mjs",
    "smoke:cloudflare": "node scripts/verify-cloudflare.mjs",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "typescript": "^5.7.4"
  }
}